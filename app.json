{
  "expo": {
    "name": "Bambuddy",
    "slug": "bambuddy-mobile",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "bambuddy",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.bambuddy.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Bambuddy uses the camera to scan QR codes on spool labels and for server setup.",
        "NFCReaderUsageDescription": "Bambuddy uses NFC to read and write SpoolBuddy spool tags.",
        "NSFaceIDUsageDescription": "Use Face ID to unlock Bambuddy."
      }
    },
    "android": {
      "package": "com.bambuddy.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#09090b",
        "foregroundImage": "./assets/images/icon.png"
      },
      "permissions": [
        "CAMERA",
        "NFC",
        "VIBRATE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-camera",
      "expo-local-authentication",
      "react-native-nfc-manager",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#10b981"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#09090b",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
